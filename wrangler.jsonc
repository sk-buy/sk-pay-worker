{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sk-pay-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-23",
  "observability": {
    "enabled": true
  },
  "secrets": {
    "required": [
      "ADMIN_TOKEN"
    ]
  },
  "kv_namespaces": [
    {
      "binding": "PAY_CONFIG",
      "id": "replace-with-your-kv-namespace-id"
    }
  ],
  "vars": {}
}
